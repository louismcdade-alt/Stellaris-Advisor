# ───────────────────────── Secrets / credentials ─────────────────────────
# The core is offline by design (no API keys), but never commit secrets if added
# later (e.g. an optional Claude API layer would need a key).
.env
.env.*
*.env
secrets.*
*.secret
credentials*.json
*.key
*.pem
*.pfx
*.p12
api_key*
*_api_key*
.netrc

# ───────────────────────── Python ─────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments / dependency folders
.venv/
venv/
env/
ENV/
.python-version
pip-wheel-metadata/
*.egg-info/
.eggs/

# Build / packaging output
build/
dist/
*.egg

# Test / coverage / type-check caches (for the planned pytest suite)
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.tox/

# ───────────────────────── Node / frontend (frontend/) ─────────────────────────
# The frontend is a Vite/React app, built at dev time to frontend/dist/ (already
# covered by the generic dist/ rule above) and served as static files by the
# stdlib-only Python server -- node_modules is a local dependency cache, never
# committed. Run `npm install && npm run build` in frontend/ before first run.
node_modules/

# ───────────────────────── Runtime-generated (this app) ─────────────────────────
# Runtime log written by app.py (stdout/stderr redirect). Regenerated each run.
advisor.log
*.log

# Local user/runtime state written by the app, kept out of the repo.
# (last_campaign.txt is written if backlog item #9 — persist campaign — is built.)
last_campaign.txt

# ───────────────────────── Local tooling / editor / OS ─────────────────────────
# .claude/settings.local.json holds local Claude Code tool permissions.
.claude/settings.local.json
.vscode/
.idea/
*.swp
*~
Thumbs.db
desktop.ini
.DS_Store

# ───────────────────────── NOT ignored (intentional — see notes) ─────────────────────────
# logo.svg              source art for the icon (tracked)
# icon.ico / icon.png   generated by make_icon.py but required at runtime by app.py,
#                       and regenerating needs Pillow — so they are committed.
# owned_dlc.txt         small user-editable DLC config the app reads; committed as a
#                       working example. Uncomment below if you'd rather keep your
#                       personal DLC list out of the repo:
# owned_dlc.txt
